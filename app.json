{
  "expo": {
    "name": "Minty",
    "slug": "grademycard",
    "owner": "bsong",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "minty",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0C",
    "icon": "./src/assets/icon.png",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0C"
    },
    "ios": {
      "bundleIdentifier": "com.bsong.mintyyy",
      "buildNumber": "53",
      "supportsTablet": false,
      "splash": {
        "image": "./src/assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A0A0C"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Minty uses your camera so you can photograph a trading card and receive an AI-predicted grade estimate based on the photo.",
        "NSPhotoLibraryUsageDescription": "Minty accesses your photo library so you can choose an existing card photo to grade.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "output": "server",
      "backgroundColor": "#0A0A0C"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.bsong.minty",
      "splash": {
        "image": "./src/assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A0A0C"
      },
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-font",
      "expo-image",
      "expo-router",
      "expo-web-browser",
      "@bacons/apple-colors",
      "expo-asset",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Minty uses your camera so you can photograph a trading card and receive an AI-predicted grade estimate based on the photo."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Minty accesses your photo library so you can choose an existing card photo to grade."
        }
      ],
      "react-native-document-scanner-plugin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eafbd7db-3c15-44e4-87d0-fc629985a17a"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/eafbd7db-3c15-44e4-87d0-fc629985a17a"
    }
  }
}
